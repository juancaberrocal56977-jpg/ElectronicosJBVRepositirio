<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
	</configSections>
	<appSettings>
		<add key="NombreEmpresa" value="UTN Company." />
		<add key="URLPadron" value="https://api.hacienda.go.cr/fe/ae?identificacion=" />
		<add key="URLProvincia" value="https://raw.githubusercontent.com/lateraluz/Datos/refs/heads/master/provincias.json" />
		<add key="ClientSettingsProvider.ServiceUri" value="" />
	</appSettings>
	<connectionStrings>
		<add name="dataBase" connectionString="Data Source=localhost;Initial Catalog=DBElectronicosJBV;Persist Security Info=True;User ID=sa;Password=123456" providerName="System.Data.SqlClient" />
		<!--<add name="UTNLeccion8B.Properties.Settings.dataBase" connectionString="Data Source=.;Initial Catalog=Leccion8B;Persist Security Info=True;User ID=sa;Password=123456;TrustServerCertificate=True"
      providerName="System.Data.SqlClient" />-->
	</connectionStrings>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>
	<system.serviceModel>
		<bindings>
			<basicHttpBinding>
				<binding name="wsindicadoreseconomicosSoap">
					<security mode="Transport" />
				</binding>
				<binding name="wsindicadoreseconomicosSoap1" />
				<binding name="wsindicadoreseconomicosSoap2">
					<security mode="Transport" />
				</binding>
				<binding name="wsindicadoreseconomicosSoap3" />
			</basicHttpBinding>
			<customBinding>
				<binding name="wsindicadoreseconomicosSoap12">
					<textMessageEncoding messageVersion="Soap12" />
					<httpsTransport />
				</binding>
				<binding name="wsindicadoreseconomicosSoap121">
					<textMessageEncoding messageVersion="Soap12" />
					<httpsTransport />
				</binding>
			</customBinding>
		</bindings>
		<client>
			<endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx" binding="basicHttpBinding" bindingConfiguration="wsindicadoreseconomicosSoap" contract="BCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap" />
			<endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx" binding="customBinding" bindingConfiguration="wsindicadoreseconomicosSoap12" contract="BCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap12" />
			<endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx" binding="basicHttpBinding" bindingConfiguration="wsindicadoreseconomicosSoap2" contract="BCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap1" />
			<endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx" binding="customBinding" bindingConfiguration="wsindicadoreseconomicosSoap121" contract="BCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap121" />
		</client>
	</system.serviceModel>
	<system.web>
		<membership defaultProvider="ClientAuthenticationMembershipProvider">
			<providers>
				<add name="ClientAuthenticationMembershipProvider" type="System.Web.ClientServices.Providers.ClientFormsAuthenticationMembershipProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri="" />
			</providers>
		</membership>
		<roleManager defaultProvider="ClientRoleProvider" enabled="true">
			<providers>
				<add name="ClientRoleProvider" type="System.Web.ClientServices.Providers.ClientRoleProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri="" cacheTimeout="86400" />
			</providers>
		</roleManager>
	</system.web>
</configuration>